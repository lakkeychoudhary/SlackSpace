# ─── SlackSpace Bot Configuration ──────────────────
# Copy this file to .env and fill in your tokens
#
# ╔══════════════════════════════════════════════════╗
# ║  HOW TO GET THESE TOKENS                        ║
# ╚══════════════════════════════════════════════════╝
#
# 1️⃣  SLACK_BOT_TOKEN (starts with xoxb-)
#    → Go to https://api.slack.com/apps
#    → Click your app → "OAuth & Permissions"
#    → Copy "Bot User OAuth Token"
#
# 2️⃣  SLACK_APP_TOKEN (starts with xapp-)
#    → Go to https://api.slack.com/apps
#    → Click your app → "Basic Information"
#    → Scroll to "App-Level Tokens"
#    → Generate token with "connections:write" scope

SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
GROQ_API_KEY=gsk-your-groq-api-key-here
